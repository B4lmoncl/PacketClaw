  "index": 1,
  "mode": "verdict",
  "title": {
    "de": "Objekt ist nicht gleich Objekt",
    "en": "An Object Is Not an Object"
  },
  "briefing": {
    "de": "Adressobjekte sind benannte IP-Mengen: ein Host ist genau EINE Adresse, ein Subnetz ein ganzer Block. Die Firewall matcht die IP des Pakets gegen die Menge — nicht gegen den Namen.",
    "en": "Address objects are named IP sets: a host is exactly ONE address, a subnet a whole block. The firewall matches the packet's IP against the set — not against the name."
  },
  "difficulty": 1,
  "concepts": ["host-vs-subnet"],
  "targetSeconds": 45,
