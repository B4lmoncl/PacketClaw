  "title": {
    "de": "Service: alles. Grund: keiner.",
    "en": "Service: Everything. Reason: None."
  },
  "briefing": {
    "de": "Härten heißt: Ersetze breite Einträge durch das, was wirklich gebraucht wird. Die Suite sagt dir, was gebraucht wird — HTTPS und DNS, sonst nichts.",
    "en": "Hardening means: replace broad entries with what's actually needed. The suite tells you what's needed — HTTPS and DNS, nothing else."
  },
  "ticket": {
    "de": "Finding A-22: 'Policy 1 erlaubt dem LAN sämtliche Services ins Internet.' Belegt genutzt: HTTPS, DNS. Alles andere: Beifang. Fass die Regel enger.",
    "en": "Finding A-22: 'Policy 1 allows the LAN every service to the internet.' Documented usage: HTTPS, DNS. Everything else: bycatch. Narrow the rule."
  },
