  "mode": "audit",
  "title": {
    "de": "Die Gruppe schluckt das Mitglied",
    "en": "The Group Swallows the Member"
  },
  "briefing": {
    "de": "Subtiler als der Klassiker: Die frühere Regel nutzt die GRUPPE (INTERNAL), die spätere das Mitglied (GUEST_NET). Die Gruppe deckt das Mitglied vollständig ab.",
    "en": "Subtler than the classic: the earlier rule uses the GROUP (INTERNAL), the later one the member (GUEST_NET). The group fully covers the member."
  },
  "ticket": {
    "de": "'Die Gäste-DNS-Regel hat null Treffer im Log — seit Monaten.' Kein Wunder. Finde die Regel, die von einer Gruppen-Regel weiter oben komplett abgedeckt wird.",
    "en": "'The guest DNS rule has zero hits in the log — for months.' No wonder. Find the rule fully covered by a group rule higher up."
  },
  "difficulty": 2,
  "concepts": ["shadowing", "address-groups"],
  "task": "find-shadowed",
  "maxEdits": 1,
