  "chapter": 8,
  "index": 7,
  "mode": "audit",
  "title": {
    "de": "Quelle: irgendwer",
    "en": "Source: Whoever"
  },
  "briefing": {
    "de": "Diesmal ist die QUELLE zu breit: 'all' im srcaddr einer DMZ-Admin-Regel. Nur das LAN administriert die DMZ — sagt die Suite. Alles andere ist Angriffsfläche.",
    "en": "This time the SOURCE is too broad: 'all' in the srcaddr of a DMZ admin rule. Only the LAN administers the DMZ — says the suite. Everything else is attack surface."
  },
  "ticket": {
    "de": "Pentest: 'SSH in die DMZ ist aus JEDEM Netz möglich, inklusive Gast-WLAN.' Die Regel meint das LAN. Sag es ihr.",
    "en": "Pentest: 'SSH into the DMZ is possible from ANY network, including guest Wi-Fi.' The rule means the LAN. Tell it so."
  },
  "difficulty": 3,
  "concepts": ["harden-any", "least-privilege"],
  "task": "harden-any",
  "maxEdits": 2,
