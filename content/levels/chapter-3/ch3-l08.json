  "title": {
    "de": "Der TCP-Zwilling fehlt",
    "en": "The TCP Twin Is Missing"
  },
  "briefing": {
    "de": "DNS-Antworten über 512 Bytes und Zonentransfers wollen tcp/53. Wer nur udp/53 erlaubt, hat 'DNS geht — meistens'. Das Wort 'meistens' kostet dich den Feierabend.",
    "en": "DNS answers over 512 bytes and zone transfers want tcp/53. Allowing only udp/53 gives you 'DNS works — mostly'. The word 'mostly' costs you your evening."
  },
  "difficulty": 3,
  "concepts": ["tcp-vs-udp", "dns"],
  "targetSeconds": 50,
  "network": {
